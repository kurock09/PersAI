ADMIN_STEP_UP_HMAC_SECRET=replace_with_dedicated_step_up_secret
PERSAI_INTERNAL_API_TOKEN=your-persai-internal-api-token
WEB_ACTIVE_CHATS_CAP=20
QUOTA_TOKEN_BUDGET_DEFAULT=200000
QUOTA_COST_OR_TOKEN_DRIVING_TOOL_UNITS_DEFAULT=1000

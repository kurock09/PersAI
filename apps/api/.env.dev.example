CLERK_SECRET_KEY=sk_test_your_clerk_secret_key
ADMIN_STEP_UP_HMAC_SECRET=replace_with_dedicated_step_up_secret
OPENCLAW_ADAPTER_ENABLED=false
OPENCLAW_BASE_URL_FREE_SHARED_RESTRICTED=http://openclaw-free-shared-restricted.persai-dev.svc.cluster.local:18789
OPENCLAW_BASE_URL_PAID_SHARED_RESTRICTED=http://openclaw-paid-shared-restricted.persai-dev.svc.cluster.local:18789

{
  "name": "@persai/api",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.build.json --incremental false",
    "start": "node dist/main.js",
    "lint": "eslint --max-warnings=0 --ext .ts src test prisma/seed.ts",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "prisma:migrate:dev": "prisma migrate dev --schema prisma/schema.prisma",
    "prisma:migrate:deploy": "prisma migrate deploy --schema prisma/schema.prisma",
    "prisma:migrate:status": "prisma migrate status --schema prisma/schema.prisma",
    "prisma:migrate:check": "prisma migrate deploy --schema prisma/schema.prisma && prisma migrate status --schema prisma/schema.prisma",
    "prisma:seed": "tsx prisma/seed.ts",
    "test": "tsx test/step2-auth-foundation.e2e.test.ts",
    "test:memory-policy": "tsx test/memory-source-policy.test.ts",
    "test:tasks-control": "tsx test/tasks-control-resolve.test.ts",
    "test:tasks-user-controls": "tsx test/tasks-user-controls.test.ts",
    "test:subscription-state": "tsx test/subscription-state-resolve.test.ts",
    "test:capability-resolution": "tsx test/capability-resolution.test.ts",
    "test:tool-catalog-activation": "tsx test/tool-catalog-activation.test.ts",
    "test:openclaw-capability-envelope": "tsx test/openclaw-capability-envelope.test.ts",
    "test:openclaw-channel-surface-bindings": "tsx test/openclaw-channel-surface-bindings.test.ts",
    "test:telegram-integration": "tsx test/telegram-integration.test.ts",
    "test:quota-accounting": "tsx test/quota-accounting.test.ts",
    "test:enforcement-points": "tsx test/enforcement-points.test.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@clerk/backend": "^3.2.2",
    "@nestjs/common": "^11.1.17",
    "@nestjs/core": "^11.1.17",
    "@nestjs/platform-express": "^11.1.17",
    "@persai/config": "workspace:*",
    "@persai/logger": "workspace:*",
    "@persai/types": "workspace:*",
    "@prisma/client": "^6.19.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@persai/eslint-config": "workspace:*",
    "@persai/tsconfig": "workspace:*",
    "@types/node": "^24.12.0",
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "@typescript-eslint/parser": "^8.46.1",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "prisma": "^6.19.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}

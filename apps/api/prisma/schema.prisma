  actionType              String?                            @map("action_type") @db.VarChar(64)
  actionPayloadJson       Json?                              @map("action_payload_json")
  controlStatus           AssistantTaskRegistryControlStatus @map("control_status")
  nextRunAt               DateTime?                          @map("next_run_at") @db.Timestamptz(6)
  disabledAt              DateTime?                          @map("disabled_at") @db.Timestamptz(6)
  cancelledAt             DateTime?                          @map("cancelled_at") @db.Timestamptz(6)
  externalRef             String?                            @map("external_ref") @db.VarChar(128)
  payloadText             String?                            @map("reminder_payload_text") @db.Text
  scheduleJson            Json?                              @map("schedule_json")
  retryAfterAt            DateTime?                          @map("retry_after_at") @db.Timestamptz(6)
  schedulerClaimToken     String?                            @map("scheduler_claim_token") @db.VarChar(64)
  schedulerClaimEpoch     Int?                               @map("scheduler_claim_epoch")
  schedulerClaimedAt      DateTime?                          @map("scheduler_claimed_at") @db.Timestamptz(6)
  schedulerClaimExpiresAt DateTime?                          @map("scheduler_claim_expires_at") @db.Timestamptz(6)
  // ADR-074 Slice T1: proactive-push frequency safeguards (additive only).
  //   * `lastFiredAt`            — last time this task ran with `audience="user"`
  //                                and was successfully dispatched. Used by
  //                                the policy gate to enforce the 1-per-48h
  //                                rule and to anchor the 14-day auto-mute.
  //   * `lastAnsweredCheckAt`    — last time the policy evaluator looked at
  //                                whether the user replied within
  //                                ANSWERED_WINDOW_HOURS of the previous push;
  //                                kept so the unanswered counter is bumped
  //                                exactly once per push.
  //   * `consecutiveUnanswered`  — running count of pushes with no user reply
  //                                inside ANSWERED_WINDOW_HOURS; reset to 0
  //                                on ANY user-initiated message.
  // No new index — scheduler claim path filters on existing indexes; the
  // policy lookup happens per-claim (already O(1) by primary key).
  lastFiredAt             DateTime?                          @map("last_fired_at") @db.Timestamptz(6)
  lastAnsweredCheckAt     DateTime?                          @map("last_answered_check_at") @db.Timestamptz(6)
  consecutiveUnanswered   Int                                @default(0) @map("consecutive_unanswered")
  // ADR-074 F1 (background-task hygiene): the scheduler used to retry a
  // failing scheduled action ~5 times in 1.5 min by counting `RuntimeTurnReceipt`
  // rows (multiple iterations per turn → counter saturated almost immediately
  // with no exponential backoff and no observable signal). `attemptCount` is
  // bumped exactly once per `processClaimedTask` invocation that ends in a
  // failure-and-retry decision; the scheduler now uses it both to gate
  // exponential backoff and to disable a task after MAX_ATTEMPTS. `lastErrorMessage`
  // captures the last failure reason so the admin task-list can surface it.
  attemptCount            Int                                @default(0) @map("attempt_count")
  lastErrorMessage        String?                            @map("last_error_message") @db.VarChar(2000)
  lastErrorAt             DateTime?                          @map("last_error_at") @db.Timestamptz(6)
  createdAt               DateTime                           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime                           @updatedAt @map("updated_at") @db.Timestamptz(6)
  assistant               Assistant                          @relation(fields: [assistantId, userId], references: [id, userId], onDelete: Restrict, onUpdate: Cascade)
  workspaceMember         WorkspaceMember                    @relation(fields: [workspaceId, userId], references: [workspaceId, userId], onDelete: Restrict, onUpdate: Cascade)

  @@unique([assistantId, externalRef])
  @@index([assistantId, controlStatus, nextRunAt])
  @@index([controlStatus, nextRunAt, retryAfterAt, schedulerClaimExpiresAt])
  @@map("assistant_task_registry_items")
}

/// ADR-077 source of truth for assistant-side background actions. User-visible

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum WorkspaceStatus {
  active
  inactive
}

enum WorkspaceRole {
  owner
  member
}

enum AssistantApplyStatus {
  not_requested
  pending
  in_progress
  succeeded
  failed
  degraded
}

enum AssistantMaterializationSourceAction {
  publish
  rollback
  reset
}

enum AssistantChatSurface {
  web
}

enum AssistantChatMessageAuthor {
  user
  assistant
  system
}

enum AssistantMemoryRegistrySourceType {
  web_chat
}

enum AssistantTaskRegistrySourceSurface {
  web
}

enum AssistantTaskRegistryControlStatus {
  active
  disabled
  cancelled
}

enum PlanCatalogStatus {
  active
  inactive
}

enum ToolCatalogToolClass {
  cost_driving
  utility
}

enum ToolCatalogCapabilityGroup {
  knowledge
  automation
  communication
  workspace_ops
}

enum ToolCatalogStatus {
  active
  inactive
}

enum PlanToolActivationStatus {
  active
  inactive
}

enum WorkspaceSubscriptionStatus {
  trialing
  active
  grace_period
  past_due
  paused
  canceled
  expired
}

enum WorkspaceQuotaDimension {
  token_budget
  cost_or_token_driving_tool_class
  active_web_chats_cap
}

model AppUser {
  id                        String                     @id @db.Uuid @default(dbgenerated("gen_random_uuid()"))
  clerkUserId               String?                    @unique @map("clerk_user_id")
  email                     String                     @unique
  displayName               String?                    @map("display_name")
  createdAt                 DateTime                   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                 DateTime                   @updatedAt @map("updated_at") @db.Timestamptz(6)
  assistant                 Assistant?
  workspaceLinks            WorkspaceMember[]
  publishedAssistantVersion AssistantPublishedVersion[] @relation("AssistantVersionPublisher")

  @@map("app_users")
}

model Workspace {
  id        String            @id @db.Uuid @default(dbgenerated("gen_random_uuid()"))
  name      String
  locale    String
  timezone  String
  status    WorkspaceStatus
  createdAt DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  assistants Assistant[]
  members   WorkspaceMember[]
  subscription WorkspaceSubscription?
  quotaAccountingState WorkspaceQuotaAccountingState?
  quotaUsageEvents WorkspaceQuotaUsageEvent[]

  @@map("workspaces")
}

model WorkspaceMember {
  id             String          @id @db.Uuid @default(dbgenerated("gen_random_uuid()"))
  workspaceId    String          @map("workspace_id") @db.Uuid
  userId         String          @map("user_id") @db.Uuid
  role           WorkspaceRole
  createdAt      DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  assistant                   Assistant?                    @relation("AssistantWorkspaceScope")
  assistantChats              AssistantChat[]
  assistantMemoryRegistryItems AssistantMemoryRegistryItem[]
  assistantTaskRegistryItems  AssistantTaskRegistryItem[]
  workspace                   Workspace                     @relation(fields: [workspaceId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  user           AppUser         @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([workspaceId, userId])
  @@map("workspace_members")
}

model Assistant {
  id                   String                     @id @db.Uuid @default(dbgenerated("gen_random_uuid()"))
  userId               String                     @unique @map("user_id") @db.Uuid
  workspaceId          String                     @map("workspace_id") @db.Uuid
  draftDisplayName     String?                    @map("draft_display_name")
  draftInstructions    String?                    @map("draft_instructions")
  draftUpdatedAt       DateTime?                  @map("draft_updated_at") @db.Timestamptz(6)
  applyStatus          AssistantApplyStatus       @default(not_requested) @map("apply_status")
  applyTargetVersionId String?                    @map("apply_target_version_id") @db.Uuid
  applyAppliedVersionId String?                   @map("apply_applied_version_id") @db.Uuid
  applyRequestedAt     DateTime?                  @map("apply_requested_at") @db.Timestamptz(6)
  applyStartedAt       DateTime?                  @map("apply_started_at") @db.Timestamptz(6)
  applyFinishedAt      DateTime?                  @map("apply_finished_at") @db.Timestamptz(6)
  applyErrorCode       String?                    @map("apply_error_code")
  applyErrorMessage    String?                    @map("apply_error_message")
  createdAt            DateTime                   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime                   @updatedAt @map("updated_at") @db.Timestamptz(6)
  user                 AppUser                    @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  workspace            Workspace                  @relation(fields: [workspaceId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  workspaceMember      WorkspaceMember            @relation("AssistantWorkspaceScope", fields: [workspaceId, userId], references: [workspaceId, userId], onDelete: Restrict, onUpdate: Cascade)
  applyTargetVersion   AssistantPublishedVersion? @relation("AssistantApplyTargetVersion", fields: [applyTargetVersionId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  applyAppliedVersion  AssistantPublishedVersion? @relation("AssistantApplyAppliedVersion", fields: [applyAppliedVersionId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  governance       AssistantGovernance?
  materializedSpecs AssistantMaterializedSpec[]
  publishedVersions AssistantPublishedVersion[]
  chats                 AssistantChat[]
  chatMessages          AssistantChatMessage[]
  memoryRegistryItems   AssistantMemoryRegistryItem[]
  taskRegistryItems     AssistantTaskRegistryItem[]

  @@unique([workspaceId, userId])
  @@unique([id, userId])
  @@map("assistants")
}

model AssistantPublishedVersion {
  id                  String    @id @db.Uuid @default(dbgenerated("gen_random_uuid()"))
  assistantId         String    @map("assistant_id") @db.Uuid
  version             Int
  snapshotDisplayName String?   @map("snapshot_display_name")
  snapshotInstructions String?  @map("snapshot_instructions")
  publishedByUserId   String    @map("published_by_user_id") @db.Uuid
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  assistant             Assistant   @relation(fields: [assistantId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  publishedByUser       AppUser     @relation("AssistantVersionPublisher", fields: [publishedByUserId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  applyTargetAssistants Assistant[] @relation("AssistantApplyTargetVersion")
  applyAppliedAssistants Assistant[] @relation("AssistantApplyAppliedVersion")
  materializedSpec       AssistantMaterializedSpec?

  @@unique([assistantId, version])
  @@map("assistant_published_versions")
}

model AssistantGovernance {
  id                 String    @id @db.Uuid @default(dbgenerated("gen_random_uuid()"))
  assistantId        String    @unique @map("assistant_id") @db.Uuid
  capabilityEnvelope Json?     @map("capability_envelope")
  secretRefs         Json?     @map("secret_refs")
  policyEnvelope     Json?     @map("policy_envelope")
  memoryControl      Json?     @map("memory_control")
  tasksControl       Json?     @map("tasks_control")
  quotaPlanCode      String?   @map("quota_plan_code")
  quotaHook          Json?     @map("quota_hook")
  auditHook          Json?     @map("audit_hook")
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  assistant          Assistant @relation(fields: [assistantId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@map("assistant_governance")
}

model PlanCatalogPlan {
  id                            String                 @id @db.Uuid @default(dbgenerated("gen_random_uuid()"))
  code                          String                 @unique @db.VarChar(64)
  displayName                   String                 @map("display_name") @db.VarChar(120)
  description                   String?                @db.Text
  status                        PlanCatalogStatus      @default(active)
  isDefaultFirstRegistrationPlan Boolean               @default(false) @map("is_default_first_registration_plan")
  isTrialPlan                   Boolean                @default(false) @map("is_trial_plan")
  trialDurationDays             Int?                   @map("trial_duration_days")
  billingProviderHints          Json?                  @map("billing_provider_hints")
  createdAt                     DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                     DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)
  entitlement                   PlanCatalogEntitlement?
  toolActivations               PlanCatalogToolActivation[]

  @@map("plan_catalog_plans")
}

model PlanCatalogEntitlement {
  id                           String          @id @db.Uuid @default(dbgenerated("gen_random_uuid()"))
  planId                       String          @unique @map("plan_id") @db.Uuid
  schemaVersion                Int             @default(1) @map("schema_version")
  capabilities                 Json            @default("[]") @db.JsonB
  toolClasses                  Json            @default("[]") @map("tool_classes") @db.JsonB
  channelsAndSurfaces          Json            @default("[]") @map("channels_and_surfaces") @db.JsonB
  limitsPermissions            Json            @default("[]") @map("limits_permissions") @db.JsonB
  createdAt                    DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                    DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)
  plan                         PlanCatalogPlan @relation(fields: [planId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@map("plan_catalog_entitlements")
}

model ToolCatalogTool {
  id              String                     @id @db.Uuid @default(dbgenerated("gen_random_uuid()"))
  code            String                     @unique @db.VarChar(64)
  displayName     String                     @map("display_name") @db.VarChar(120)
  description     String?                    @db.Text
  capabilityGroup ToolCatalogCapabilityGroup @map("capability_group")
  toolClass       ToolCatalogToolClass       @map("tool_class")
  status          ToolCatalogStatus          @default(active)
  providerHints   Json?                      @map("provider_hints")
  createdAt       DateTime                   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime                   @updatedAt @map("updated_at") @db.Timestamptz(6)
  planActivations PlanCatalogToolActivation[]

  @@map("tool_catalog_tools")
}

model PlanCatalogToolActivation {
  id               String                   @id @db.Uuid @default(dbgenerated("gen_random_uuid()"))
  planId           String                   @map("plan_id") @db.Uuid
  toolId           String                   @map("tool_id") @db.Uuid
  activationStatus PlanToolActivationStatus @default(inactive) @map("activation_status")
  createdAt        DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime                 @updatedAt @map("updated_at") @db.Timestamptz(6)
  plan             PlanCatalogPlan          @relation(fields: [planId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  tool             ToolCatalogTool          @relation(fields: [toolId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([planId, toolId])
  @@index([planId, activationStatus])
  @@map("plan_catalog_tool_activations")
}

model WorkspaceSubscription {
  id                     String                    @id @db.Uuid @default(dbgenerated("gen_random_uuid()"))
  workspaceId            String                    @unique @map("workspace_id") @db.Uuid
  planCode               String                    @map("plan_code") @db.VarChar(64)
  status                 WorkspaceSubscriptionStatus
  trialStartedAt         DateTime?                 @map("trial_started_at") @db.Timestamptz(6)
  trialEndsAt            DateTime?                 @map("trial_ends_at") @db.Timestamptz(6)
  currentPeriodStartedAt DateTime?                 @map("current_period_started_at") @db.Timestamptz(6)
  currentPeriodEndsAt    DateTime?                 @map("current_period_ends_at") @db.Timestamptz(6)
  cancelAtPeriodEnd      Boolean                   @default(false) @map("cancel_at_period_end")
  billingProvider        String?                   @map("billing_provider") @db.VarChar(64)
  providerCustomerRef    String?                   @map("provider_customer_ref") @db.VarChar(128)
  providerSubscriptionRef String?                  @map("provider_subscription_ref") @db.VarChar(128)
  metadata               Json?                     @db.JsonB
  createdAt              DateTime                  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime                  @updatedAt @map("updated_at") @db.Timestamptz(6)
  workspace              Workspace                 @relation(fields: [workspaceId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([planCode, status])
  @@map("workspace_subscriptions")
}

model WorkspaceQuotaAccountingState {
  id                                   String   @id @db.Uuid @default(dbgenerated("gen_random_uuid()"))
  workspaceId                          String   @unique @map("workspace_id") @db.Uuid
  tokenBudgetUsed                      BigInt   @default(0) @map("token_budget_used")
  tokenBudgetLimit                     BigInt?  @map("token_budget_limit")
  costOrTokenDrivingToolClassUnitsUsed Int      @default(0) @map("cost_or_token_driving_tool_class_units_used")
  costOrTokenDrivingToolClassUnitsLimit Int?    @map("cost_or_token_driving_tool_class_units_limit")
  activeWebChatsCurrent                Int      @default(0) @map("active_web_chats_current")
  activeWebChatsLimit                  Int?     @map("active_web_chats_limit")
  lastComputedAt                       DateTime @default(now()) @map("last_computed_at") @db.Timestamptz(6)
  createdAt                            DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                            DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  workspace                            Workspace @relation(fields: [workspaceId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@map("workspace_quota_accounting_state")
}

model WorkspaceQuotaUsageEvent {
  id           String                @id @db.Uuid @default(dbgenerated("gen_random_uuid()"))
  workspaceId  String                @map("workspace_id") @db.Uuid
  assistantId  String?               @map("assistant_id") @db.Uuid
  userId       String?               @map("user_id") @db.Uuid
  dimension    WorkspaceQuotaDimension
  delta        BigInt                @default(0)
  currentValue BigInt?               @map("current_value")
  limitValue   BigInt?               @map("limit_value")
  source       String                @db.VarChar(64)
  metadata     Json?                 @db.JsonB
  createdAt    DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  workspace    Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([workspaceId, dimension, createdAt])
  @@map("workspace_quota_usage_events")
}

model AssistantMaterializedSpec {
  id                        String                              @id @db.Uuid @default(dbgenerated("gen_random_uuid()"))
  assistantId               String                              @map("assistant_id") @db.Uuid
  publishedVersionId        String                              @unique @map("published_version_id") @db.Uuid
  sourceAction              AssistantMaterializationSourceAction @map("source_action")
  algorithmVersion          Int                                 @default(1) @map("algorithm_version")
  layers                    Json                                @map("layers")
  openclawBootstrap         Json                                @map("openclaw_bootstrap")
  openclawWorkspace         Json                                @map("openclaw_workspace")
  layersDocument            String                              @map("layers_document") @db.Text
  openclawBootstrapDocument String                              @map("openclaw_bootstrap_document") @db.Text
  openclawWorkspaceDocument String                              @map("openclaw_workspace_document") @db.Text
  contentHash               String                              @map("content_hash")
  createdAt                 DateTime                            @default(now()) @map("created_at") @db.Timestamptz(6)
  assistant                 Assistant                           @relation(fields: [assistantId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  publishedVersion          AssistantPublishedVersion           @relation(fields: [publishedVersionId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@map("assistant_materialized_specs")
}

model AssistantChat {
  id               String                @id @db.Uuid @default(dbgenerated("gen_random_uuid()"))
  assistantId      String                @map("assistant_id") @db.Uuid
  userId           String                @map("user_id") @db.Uuid
  workspaceId      String                @map("workspace_id") @db.Uuid
  surface          AssistantChatSurface
  surfaceThreadKey String                @map("surface_thread_key")
  title            String?
  archivedAt       DateTime?             @map("archived_at") @db.Timestamptz(6)
  lastMessageAt    DateTime?             @map("last_message_at") @db.Timestamptz(6)
  createdAt        DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime              @updatedAt @map("updated_at") @db.Timestamptz(6)
  assistant        Assistant             @relation(fields: [assistantId, userId], references: [id, userId], onDelete: Restrict, onUpdate: Cascade)
  workspaceMember  WorkspaceMember       @relation(fields: [workspaceId, userId], references: [workspaceId, userId], onDelete: Restrict, onUpdate: Cascade)
  messages         AssistantChatMessage[]

  @@unique([assistantId, surface, surfaceThreadKey])
  @@unique([id, assistantId])
  @@map("assistant_chats")
}

model AssistantChatMessage {
  id          String                     @id @db.Uuid @default(dbgenerated("gen_random_uuid()"))
  chatId      String                     @map("chat_id") @db.Uuid
  assistantId String                     @map("assistant_id") @db.Uuid
  author      AssistantChatMessageAuthor
  content     String                     @db.Text
  createdAt   DateTime                   @default(now()) @map("created_at") @db.Timestamptz(6)
  chat        AssistantChat              @relation(fields: [chatId, assistantId], references: [id, assistantId], onDelete: Restrict, onUpdate: Cascade)
  assistant   Assistant                  @relation(fields: [assistantId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([chatId, createdAt])
  @@map("assistant_chat_messages")
}

model AssistantMemoryRegistryItem {
  id                        String                           @id @db.Uuid @default(dbgenerated("gen_random_uuid()"))
  assistantId               String                           @map("assistant_id") @db.Uuid
  userId                    String                           @map("user_id") @db.Uuid
  workspaceId               String                           @map("workspace_id") @db.Uuid
  chatId                    String?                          @map("chat_id") @db.Uuid
  relatedUserMessageId      String?                          @map("related_user_message_id") @db.Uuid
  relatedAssistantMessageId String?                          @map("related_assistant_message_id") @db.Uuid
  summary                   String                           @db.VarChar(500)
  sourceType                AssistantMemoryRegistrySourceType @map("source_type")
  sourceLabel               String?                          @map("source_label") @db.VarChar(64)
  forgottenAt               DateTime?                        @map("forgotten_at") @db.Timestamptz(6)
  createdAt                 DateTime                         @default(now()) @map("created_at") @db.Timestamptz(6)
  assistant                 Assistant                        @relation(fields: [assistantId, userId], references: [id, userId], onDelete: Restrict, onUpdate: Cascade)
  workspaceMember           WorkspaceMember                  @relation(fields: [workspaceId, userId], references: [workspaceId, userId], onDelete: Restrict, onUpdate: Cascade)

  @@index([assistantId, createdAt(sort: Desc)])
  @@map("assistant_memory_registry_items")
}

model AssistantTaskRegistryItem {
  id              String                           @id @db.Uuid @default(dbgenerated("gen_random_uuid()"))
  assistantId     String                           @map("assistant_id") @db.Uuid
  userId          String                           @map("user_id") @db.Uuid
  workspaceId     String                           @map("workspace_id") @db.Uuid
  title           String                           @db.VarChar(500)
  sourceSurface   AssistantTaskRegistrySourceSurface @map("source_surface")
  sourceLabel     String?                          @map("source_label") @db.VarChar(64)
  controlStatus   AssistantTaskRegistryControlStatus @map("control_status")
  nextRunAt       DateTime?                        @map("next_run_at") @db.Timestamptz(6)
  disabledAt      DateTime?                        @map("disabled_at") @db.Timestamptz(6)
  cancelledAt     DateTime?                        @map("cancelled_at") @db.Timestamptz(6)
  externalRef     String?                          @map("external_ref") @db.VarChar(128)
  createdAt       DateTime                         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime                         @updatedAt @map("updated_at") @db.Timestamptz(6)
  assistant       Assistant                        @relation(fields: [assistantId, userId], references: [id, userId], onDelete: Restrict, onUpdate: Cascade)
  workspaceMember WorkspaceMember                  @relation(fields: [workspaceId, userId], references: [workspaceId, userId], onDelete: Restrict, onUpdate: Cascade)

  @@index([assistantId, controlStatus, nextRunAt])
  @@map("assistant_task_registry_items")
}

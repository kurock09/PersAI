/// ADR-074 V1 — editable Voice DNA archetypes. Seeded from
/// `apps/api/prisma/persona-archetype-data.ts` (insert-only upsert), then
/// edited through the admin UI without redeploys. Runtime always reads from
/// this table; published versions snapshot the resolved Voice DNA into
/// `assistant_published_versions.snapshot_voice_dna` so already-published
/// assistants stay stable when admins later edit the source archetype.
/// ADR-074 Slice M2 — durable background queue for off-band session
/// compaction. The user-perceived turn ends at `completeAcceptedTurn`;
/// `apps/api`'s `PersaiBackgroundCompactionSchedulerService` polls this table,
/// claims pending jobs with a TTL lease, and POSTs them to the runtime's
/// internal `/api/v1/internal/runtime/sessions/compact-and-extract` endpoint.
///
/// One pending job per `(assistantId, channel, externalThreadKey)` triple is
/// enforced via `pendingDedupeKey`, so multiple "please compact" enqueues for
/// the same conversation collapse into a single durable job (supersede-on-
/// enqueue). Once the job is claimed the dedupe key is cleared so the next
/// enqueue can re-create a fresh row.
model AssistantBackgroundCompactionJob {
  id                      String                                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  assistantId             String                                  @map("assistant_id") @db.Uuid
  workspaceId             String                                  @map("workspace_id") @db.Uuid
  channel                 RuntimeConversationChannel
  externalThreadKey       String                                  @map("external_thread_key") @db.VarChar(255)
  externalUserKey         String?                                 @map("external_user_key") @db.VarChar(255)
  runtimeTier             RuntimeTier                             @map("runtime_tier")
  trigger                 AssistantBackgroundCompactionJobTrigger @default(post_turn)
  status                  AssistantBackgroundCompactionJobStatus  @default(pending)
  pendingDedupeKey        String?                                 @map("pending_dedupe_key") @db.VarChar(512)
  attemptCount            Int                                     @default(0) @map("attempt_count")
  enqueuedRequestId       String?                                 @map("enqueued_request_id") @db.VarChar(128)
  schedulerClaimToken     String?                                 @map("scheduler_claim_token") @db.VarChar(64)
  schedulerClaimEpoch     Int?                                    @map("scheduler_claim_epoch")
  schedulerClaimedAt      DateTime?                               @map("scheduler_claimed_at") @db.Timestamptz(6)
  schedulerClaimExpiresAt DateTime?                               @map("scheduler_claim_expires_at") @db.Timestamptz(6)
  retryAfterAt            DateTime?                               @map("retry_after_at") @db.Timestamptz(6)
  lastErrorCode           String?                                 @map("last_error_code") @db.VarChar(128)
  lastErrorMessage        String?                                 @map("last_error_message") @db.Text
  lastResultPayload       Json?                                   @map("last_result_payload") @db.JsonB
  completedAt             DateTime?                               @map("completed_at") @db.Timestamptz(6)
  createdAt               DateTime                                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime                                @updatedAt @map("updated_at") @db.Timestamptz(6)
  assistant               Assistant                               @relation(fields: [assistantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  workspace               Workspace                               @relation(fields: [workspaceId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([pendingDedupeKey])
  @@index([status, retryAfterAt, createdAt])
  @@index([assistantId, channel, externalThreadKey, createdAt(sort: Desc)])
  @@index([workspaceId, status, createdAt(sort: Desc)])
  @@map("assistant_background_compaction_jobs")
}

enum AssistantBackgroundCompactionJobStatus {
  pending
  in_progress
  completed
  failed
}

model SchedulerLease {
  /// Stable scheduler identifier — one row per scheduler kind. Examples:
  /// "idle_reengagement", "background_task", "background_compaction", "media_job".
  schedulerKey  String   @id @map("scheduler_key") @db.VarChar(64)
  /// Pod-unique holder id (e.g. process uuid + pod name). Used to validate
  /// heartbeat updates so a stale leader cannot extend an expired lease.
  holderId      String   @map("holder_id") @db.VarChar(255)
  /// Random per-acquisition token. The leader checks this token on every
  /// heartbeat / release; another pod that took over after expiry uses a new
  /// token and the previous leader's heartbeat will silently fail.
  leaseToken    String   @map("lease_token") @db.VarChar(128)
  /// Hard deadline. After this point any pod may acquire the lease.
  expiresAt     DateTime @map("expires_at") @db.Timestamptz(6)
  /// Last time the leader confirmed it is still alive.
  lastHeartbeat DateTime @map("last_heartbeat") @db.Timestamptz(6)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([expiresAt])
  @@map("scheduler_leases")
}

// ADR-090: Durable per-(assistant, chat) state for idle re-engagement evaluation.
// Primary cooldown and attempt-budget source of truth; replaces the fragile
// notificationIntent lifecycle filter that missed failed/dead_letter states.
model AssistantIdleEvaluationMarker {
  id                            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId                   String    @map("workspace_id") @db.Uuid
  assistantId                   String    @map("assistant_id") @db.Uuid
  chatId                        String    @map("chat_id") @db.Uuid
  /// ISO timestamp of the user message that opened the current evaluation window.
  latestUserMessageAtSnapshot   DateTime  @map("latest_user_message_at_snapshot") @db.Timestamptz(6)
  /// Last LLM decision: push | no_push | complete | error
  lastDecision                  String    @map("last_decision") @db.VarChar(32)
  /// Number of evaluate() calls made for the current user-message snapshot.
  attemptsForCurrentUserMessage Int       @default(0) @map("attempts_for_current_user_message")
  /// When set, scheduler must not evaluate this marker before this time.
  nextEligibleEvaluationAt      DateTime? @map("next_eligible_evaluation_at") @db.Timestamptz(6)
  createdAt                     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                     DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([assistantId, chatId])
  @@index([assistantId])
  @@index([workspaceId])
  @@map("assistant_idle_evaluation_markers")
}


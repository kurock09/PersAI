/// ADR-108 Slice 1 — Workspace-scoped Vcoin (VC) wallet for `video_generate`
/// settlement. The course is platform-level (`PlatformRuntimeProviderSettings.vcoinExchangeRate`,
/// default 20 → `1 USD = 20 VC`). This slice introduces the table and a
/// read-only get-or-create access path; no debit/credit operations exist
/// yet (those land in ADR-108 Slices 2/3/4). `balance_vc` is a non-negative
/// integer except for the one-shot negative balance permitted by the
/// lifecycle rule (settle-only debit can drive the balance just below zero
/// exactly once; the next enqueue is rejected with
/// `vcoin_balance_exhausted`). Image / TTS / STT / document quotas remain
/// per-unit and are NOT affected by this wallet.
model WorkspaceVcoinBalance {
  workspaceId String    @id @map("workspace_id") @db.Uuid
  balanceVc   Int       @default(0) @map("balance_vc")
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@map("workspace_vcoin_balances")
}

/**
 * ADR-108 Slice 3 — append-only VC ledger event.
 * This table serves two purposes:
 * 1. Idempotency gate: the UNIQUE constraint on (workspaceId, kind, referenceKey)
 * prevents the same logical event from being applied twice. A Prisma P2002
 * error on insert signals "already applied" to the caller.
 * 2. Audit trail: each credit/debit event is persisted here with its kind
 * discriminator and signed amountVc (positive = credit, negative = debit).
 * Slice 3 only writes kind = "monthly_grant". Slice 4 will add
 * "package_purchase" / "package_refund". A "manual" kind is reserved for
 * future operator tooling.
 * referenceKey semantics by kind:
 * - "monthly_grant": ISO 8601 UTC string of periodStartedAt
 * (e.g. "2026-06-01T00:00:00.000Z")
 * - "package_purchase": future — Slice 4 will document this
 * This table is independent of and parallel to model_cost_ledger_events
 * (the USD COGS ledger). ADR-108 cross-slice invariant 2 requires
 * model_cost_ledger_events to remain unchanged in shape and write site.
 */
model WorkspaceVcoinLedgerEvent {
  id           String   @id @default(uuid())
  workspaceId  String   @map("workspace_id") @db.Uuid
  kind         String
  amountVc     Int      @map("amount_vc")
  referenceKey String   @map("reference_key")
  planCode     String?  @map("plan_code")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([workspaceId, kind, referenceKey], name: "uniq_workspace_vcoin_ledger_event_kind_ref")
  @@index([workspaceId, kind])
  @@map("workspace_vcoin_ledger_events")
}


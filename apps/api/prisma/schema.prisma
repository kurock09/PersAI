  helperModelKey          String?                       @map("helper_model_key") @db.VarChar(255)
  helperProviderKey       String?                       @map("helper_provider_key") @db.VarChar(64)
  helperInputTokens       Int?                          @map("helper_input_tokens")
  helperOutputTokens      Int?                          @map("helper_output_tokens")
  helperTotalTokens       Int?                          @map("helper_total_tokens")
  errorCode               String?                       @map("error_code") @db.VarChar(128)
  durationMs              Int                           @map("duration_ms")
  /// ADR-094 — short tag for the response shape the retrieval seam chose for
  /// this event (e.g. "smart_inline_full" / "smart_inline_section" /
  /// "smart_inline_summary" / "snippet_only" for search, "short" / "section" /

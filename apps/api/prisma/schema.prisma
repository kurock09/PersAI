}

/// ADR-125 — per-chat hierarchical todo list owned by the model via the
/// `todo_write` native tool. The server is source of truth: it enforces
/// single in_progress per parent, no resurrection of completed items, child-
/// before-parent completion, and the soft 200 / hard 500 row cap. `sortOrder`
/// keeps the model-declared in-list ordering within a parent scope; new items
/// append (`max(sortOrder)+1`). All rows are model-authored — the model owns
/// the entire plan lifecycle including scenario intake via the `todo_write`
/// tool when `skill.engage` returns scenario steps.
model AssistantChatTodo {
  id                 String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  chatId             String                  @map("chat_id") @db.Uuid
  assistantId        String                  @map("assistant_id") @db.Uuid
  parentId           String?                 @map("parent_id") @db.Uuid
  content            String                  @db.Text
  status             AssistantChatTodoStatus @default(pending)
  sortOrder          Int                     @map("sort_order")
  completionCriteria Json?                   @map("completion_criteria") @db.JsonB
  createdAt          DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime                @updatedAt @map("updated_at") @db.Timestamptz(6)
  completedAt        DateTime?               @map("completed_at") @db.Timestamptz(6)
  chat               AssistantChat           @relation(fields: [chatId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  parent             AssistantChatTodo?      @relation("AssistantChatTodoChildren", fields: [parentId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  children           AssistantChatTodo[]     @relation("AssistantChatTodoChildren")

  @@index([chatId, sortOrder])
  @@index([chatId, parentId, sortOrder])
  @@index([parentId])
  @@map("assistant_chat_todos")
}


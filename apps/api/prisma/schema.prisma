/// ADR-126 Slice 3 — deferred garbage-collection schedule for sandbox workspace
/// content (warm-pod scratch and the GCS snapshot subtree). Path-based file
/// identity (`workspace_file_metadata`, `assistant_chat_message_attachment.storagePath`)
/// is purged by the reaper from GCS prefixes and warm pods; the lease is
/// **deliberately independent** of the source rows (`Assistant`, `Workspace`, chat)
/// so the chat / assistant / workspace hard-delete transactions can continue to
/// remove their source rows atomically while the deferred purge of out-of-line
/// state (GCS prefixes, warm pods) survives the disappearance of the source row.
/// The producing service
/// writes the lease inside the same Prisma transaction that performs the
/// hard-delete, so atomicity is: lease exists ↔ source row gone.
///
/// `kind` selects the purge routine and metadata schema:
///   - `chat_scratch`:        `targetId = chatId`,
///                            `metadata = {workspaceId, assistantId}`,
///                            `scheduledAt = now()`.
///   - `assistant_outbound`:  `targetId = assistantId`,
///                            `metadata = {workspaceId, handle}`,
///                            `scheduledAt = now() + 7 days`.
///   - `workspace_shared`:    `targetId = workspaceId`,
///                            `metadata = {}`,
///                            `scheduledAt = now() + 30 days`.
///
/// The reaper (apps/sandbox/src/workspace-gc.service.ts) polls due rows where
/// `purged_at IS NULL AND scheduled_at <= now()`, validates `metadata` against a
/// kind-specific Zod schema, runs the purge, then sets `purged_at = now()` on
/// success. Failed purges leave the row open and are retried on the next tick.
model SandboxWorkspaceGcLease {
  id          String                      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  kind        SandboxWorkspaceGcLeaseKind
  targetId    String                      @map("target_id") @db.Uuid
  scheduledAt DateTime                    @map("scheduled_at") @db.Timestamptz(6)
  purgedAt    DateTime?                   @map("purged_at") @db.Timestamptz(6)
  metadata    Json                        @db.JsonB
  createdAt   DateTime                    @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([kind, scheduledAt, purgedAt])
  @@index([targetId, kind])
  @@map("sandbox_workspace_gc_lease")
}

enum SandboxWorkspaceGcLeaseKind {
  chat_scratch
  assistant_outbound
  workspace_shared
}


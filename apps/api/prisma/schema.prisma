// ─── ADR-088: Unified notification platform ────────────────────────────────

enum NotificationSource {
  idle_reengagement
  quota_advisory
  reminder
  background_task_push
  billing_lifecycle
  admin_system
  system_event
  user_support
}

enum SupportTicketStatus {
  open
  pending
  answered
  closed
}

enum SupportTicketMessageAuthor {
  user
  admin
  system
}

enum NotificationClass {
  conversational
  transactional
  operational
  administrative
}

enum NotificationPriority {
  immediate
  scheduled
  digest
  skippable
}

enum NotificationLifecycleStatus {
  pending
  claimed
  delivered
  failed
  dead_letter
  skipped
  deferred_quiet_hours
  deferred_rate_limit
}

enum NotificationRenderStrategy {
  grounded_llm
  template
  static_fallback
}

enum NotificationDeliveryAttemptStatus {
  pending
  sent
  delivered
  failed
  bounced
  complaint
  escalated
}

enum NotificationChannelType {
  telegram_thread
  web_thread
  web_notification_center
  email
  admin_webhook
  web_push
  mobile_push
  user_preferred
  current_thread
}

enum NotificationChannelHealth {
  healthy
  degraded
  down
  unconfigured
}

enum NotificationQuietHoursTimezoneMode {
  workspace_default
  per_user_resolved
}

model NotificationIntent {
  id                     String                        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId            String                        @map("workspace_id") @db.Uuid
  assistantId            String?                       @map("assistant_id") @db.Uuid
  userId                 String?                       @map("user_id") @db.Uuid
  source                 NotificationSource
  class                  NotificationClass             @map("class")
  priority               NotificationPriority
  lifecycleStatus        NotificationLifecycleStatus   @default(pending) @map("lifecycle_status")
  renderStrategy         NotificationRenderStrategy    @map("render_strategy")
  renderInstructionRef   String?                       @map("render_instruction_ref") @db.Text
  templateId             String?                       @map("template_id") @db.Text
  factPayload            Json                          @map("fact_payload") @db.JsonB
  policySnapshot         Json                          @map("policy_snapshot") @db.JsonB
  allowedChannels        String[]                      @map("allowed_channels")
  escalationAfterMinutes Int?                          @map("escalation_after_minutes")
  escalationChannel      String?                       @map("escalation_channel") @db.VarChar(64)
  dedupeKey              String?                       @map("dedupe_key") @db.VarChar(512)
  scheduledAt            DateTime?                     @map("scheduled_at") @db.Timestamptz(6)
  respectQuietHours      Boolean                       @default(true) @map("respect_quiet_hours")
  surface                String?                       @db.VarChar(64)
  surfaceThreadKey       String?                       @map("surface_thread_key") @db.VarChar(255)
  chatId                 String?                       @map("chat_id") @db.Uuid
  traceId                String?                       @map("trace_id") @db.VarChar(255)
  failureReason          String?                       @map("failure_reason") @db.Text
  createdAt              DateTime                      @default(now()) @map("created_at") @db.Timestamptz(6)
  claimedAt              DateTime?                     @map("claimed_at") @db.Timestamptz(6)
  deliveredAt            DateTime?                     @map("delivered_at") @db.Timestamptz(6)
  deadLetteredAt         DateTime?                     @map("dead_lettered_at") @db.Timestamptz(6)
  workspace              Workspace                     @relation("NotificationIntentWorkspace", fields: [workspaceId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  assistant              Assistant?                    @relation("NotificationIntentAssistant", fields: [assistantId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  user                   AppUser?                      @relation("NotificationIntentUser", fields: [userId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  deliveryAttempts       NotificationDeliveryAttempt[]
  deadLetter             NotificationDeadLetter?

  @@unique([workspaceId, dedupeKey])
  @@index([workspaceId, lifecycleStatus, scheduledAt, createdAt])
  @@index([workspaceId, source, lifecycleStatus, createdAt(sort: Desc)])
  @@index([assistantId, lifecycleStatus, createdAt(sort: Desc)])
  @@map("notification_intents")
}

model NotificationDeliveryAttempt {
  id                  String                            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  intentId            String                            @map("intent_id") @db.Uuid
  attemptNumber       Int                               @map("attempt_number")
  channel             String                            @db.VarChar(64)
  status              NotificationDeliveryAttemptStatus @default(pending)
  providerRef         String?                           @map("provider_ref") @db.VarChar(255)
  error               Json?                             @db.JsonB
  escalationOf        String?                           @map("escalation_of") @db.Uuid
  startedAt           DateTime                          @default(now()) @map("started_at") @db.Timestamptz(6)
  completedAt         DateTime?                         @map("completed_at") @db.Timestamptz(6)
  intent              NotificationIntent                @relation(fields: [intentId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  escalationOfAttempt NotificationDeliveryAttempt?      @relation("EscalationChain", fields: [escalationOf], references: [id], onDelete: SetNull, onUpdate: Cascade)
  escalationAttempts  NotificationDeliveryAttempt[]     @relation("EscalationChain")

  @@index([intentId, attemptNumber])
  @@index([intentId, status])
  @@map("notification_delivery_attempts")
}

model NotificationChannelRegistry {
  id                  String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  channelType         NotificationChannelType   @unique @map("channel_type")
  enabled             Boolean                   @default(false)
  config              Json                      @db.JsonB
  healthStatus        NotificationChannelHealth @default(unconfigured) @map("health_status")
  consecutiveFailures Int                       @default(0) @map("consecutive_failures")
  lastDeliveryAt      DateTime?                 @map("last_delivery_at") @db.Timestamptz(6)
  lastFailureAt       DateTime?                 @map("last_failure_at") @db.Timestamptz(6)
  createdAt           DateTime                  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime                  @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("notification_channel_registry")
}

model NotificationPolicy {
  id                     String                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  source                 NotificationSource         @unique
  enabled                Boolean                    @default(false)
  channels               String[]
  cooldownMinutes        Int?                       @map("cooldown_minutes")
  maxPerDay              Int?                       @map("max_per_day")
  escalationAfterMinutes Int?                       @map("escalation_after_minutes")
  escalationChannel      String?                    @map("escalation_channel") @db.VarChar(64)
  respectQuietHours      Boolean                    @default(true) @map("respect_quiet_hours")
  renderStrategy         NotificationRenderStrategy @map("render_strategy")
  renderInstructionRef   String?                    @map("render_instruction_ref") @db.Text
  templateId             String?                    @map("template_id") @db.Text
  config                 Json                       @db.JsonB
  createdAt              DateTime                   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime                   @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("notification_policies")
}

model NotificationQuietHours {
  id               String                             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  singleton        Boolean                            @unique @default(true)
  enabled          Boolean                            @default(false)
  startLocal       String                             @default("22:00") @map("start_local") @db.VarChar(5)
  endLocal         String                             @default("08:00") @map("end_local") @db.VarChar(5)
  timezoneMode     NotificationQuietHoursTimezoneMode @default(workspace_default) @map("timezone_mode")
  defaultTimezone  String?                            @map("default_timezone") @db.VarChar(64)
  appliesToSources String[]                           @map("applies_to_sources")
  createdAt        DateTime                           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime                           @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("notification_quiet_hours")
}

model NotificationDeadLetter {
  id                 String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  intentId           String             @unique @map("intent_id") @db.Uuid
  workspaceId        String             @map("workspace_id") @db.Uuid
  lastError          Json               @map("last_error") @db.JsonB
  escalationAttempts Int                @default(0) @map("escalation_attempts")
  claimedForReplayAt DateTime?          @map("claimed_for_replay_at") @db.Timestamptz(6)
  resolvedAt         DateTime?          @map("resolved_at") @db.Timestamptz(6)
  createdAt          DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  intent             NotificationIntent @relation(fields: [intentId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  workspace          Workspace          @relation("NotificationDeadLetterWorkspace", fields: [workspaceId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([workspaceId, resolvedAt, createdAt(sort: Desc)])
  @@map("notification_dead_letters")
}

// ─── User support tickets ───────────────────────────────────────────────────

model SupportTicket {
  id             String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String                 @map("user_id") @db.Uuid
  workspaceId    String                 @map("workspace_id") @db.Uuid
  assistantId    String                 @map("assistant_id") @db.Uuid
  status         SupportTicketStatus    @default(open)
  subject        String?                @db.VarChar(200)
  createdAt      DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)
  answeredAt     DateTime?              @map("answered_at") @db.Timestamptz(6)
  closedAt       DateTime?              @map("closed_at") @db.Timestamptz(6)
  userLastReadAt DateTime?              @map("user_last_read_at") @db.Timestamptz(6)
  user           AppUser                @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  workspace      Workspace              @relation(fields: [workspaceId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  assistant      Assistant              @relation(fields: [assistantId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  messages       SupportTicketMessage[]

  @@index([userId, assistantId, createdAt(sort: Desc)])
  @@index([status, updatedAt(sort: Desc)])
  @@index([workspaceId, createdAt(sort: Desc)])
  @@map("support_tickets")
}

model SupportTicketMessage {
  id          String                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ticketId    String                     @map("ticket_id") @db.Uuid
  author      SupportTicketMessageAuthor
  body        String                     @db.Text
  adminUserId String?                    @map("admin_user_id") @db.Uuid
  createdAt   DateTime                   @default(now()) @map("created_at") @db.Timestamptz(6)
  ticket      SupportTicket              @relation(fields: [ticketId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  adminUser   AppUser?                   @relation("SupportTicketMessageAdminAuthor", fields: [adminUserId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  attachments SupportTicketAttachment[]

  @@index([ticketId, createdAt(sort: Asc)])
  @@map("support_ticket_messages")
}

model SupportTicketAttachment {
  id        String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  messageId String               @map("message_id") @db.Uuid
  objectKey String               @map("object_key") @db.VarChar(512)
  mimeType  String               @map("mime_type") @db.VarChar(128)
  fileName  String?              @map("file_name") @db.VarChar(255)
  sizeBytes Int                  @map("size_bytes")
  createdAt DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  message   SupportTicketMessage @relation(fields: [messageId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([messageId, createdAt(sort: Asc)])
  @@map("support_ticket_attachments")
}

enum WorkspaceVideoClonedVoiceStatus {
  pending
  ready
  failed
}

/// ADR-109 Slice 5 — workspace-scoped talking-avatar persona.
///
/// One persona = one HeyGen avatar identity (display name + voice binding +
/// portrait). `heygenAvatarId` is set eagerly on persona POST per ADR-109
/// erratum E12. NEVER exposed on user-facing list/create API (invariant #5).
///
/// Soft-delete: the `archived` flag is set to true on delete (the row is kept
/// so archived avatar IDs remain available for future cleanup tooling).
///
/// Known limitation: filtered unique index on (workspaceId, displayNameLower,
/// archived=false) would allow name reuse after archive; current unconditional
/// unique blocks reuse. Acknowledged in ADR-109.
model WorkspaceVideoPersona {
  id                      String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId             String    @map("workspace_id") @db.Uuid
  displayName             String    @map("display_name") @db.VarChar(80)
  displayNameLower        String    @map("display_name_lower") @db.VarChar(80)
  portraitImageUrl        String    @map("portrait_image_url")
  portraitImageStorageKey String    @map("portrait_image_storage_key")
  videoFormat             String    @map("video_format") @db.VarChar(8)
  heygenVoiceId           String    @map("heygen_voice_id") @db.VarChar(128)
  heygenVoiceLabel        String    @map("heygen_voice_label") @db.VarChar(120)
  heygenAvatarId          String    @map("heygen_avatar_id") @db.VarChar(128)
  clonedVoiceId           String?   @map("cloned_voice_id") @db.Uuid
  archived                Boolean   @default(false)
  archivedAt              DateTime? @map("archived_at") @db.Timestamptz(6)
  createdAt               DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  workspace   Workspace                  @relation(fields: [workspaceId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  clonedVoice WorkspaceVideoClonedVoice? @relation("WorkspaceVideoPersonaClonedVoice", fields: [workspaceId, clonedVoiceId], references: [workspaceId, id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([workspaceId, displayNameLower], name: "uniq_workspace_video_persona_name")
  @@index([workspaceId, archived])
  @@index([workspaceId, clonedVoiceId])
  @@map("workspace_video_personas")
}

/// ADR-111 Slice 3 — workspace-scoped HeyGen cloned voice substrate.
///
/// One row = one reusable workspace voice resource. The row is never assistant-
/// scoped. `heygenVoiceCloneId` is provider metadata and must not be surfaced as
/// a user-facing label.
///
/// Soft-delete: the `archived` flag is set to true on delete so historical rows
/// remain available for audit / future cleanup tooling.
///
/// Known limitation: like `WorkspaceVideoPersona`, the unconditional unique
/// constraint on `(workspaceId, displayNameLower)` blocks name reuse after
/// archive. ADR-111 accepts this for now instead of introducing a filtered
/// unique index in this slice.
model WorkspaceVideoClonedVoice {
  id                 String                          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId        String                          @map("workspace_id") @db.Uuid
  displayName        String                          @map("display_name") @db.VarChar(80)
  displayNameLower   String                          @map("display_name_lower") @db.VarChar(80)
  heygenVoiceCloneId String?                         @map("heygen_voice_clone_id") @db.VarChar(128)
  languageHint       String?                         @map("language_hint") @db.VarChar(32)
  status             WorkspaceVideoClonedVoiceStatus @default(pending)
  isDefault          Boolean                         @default(false) @map("is_default")
  previewAudioUrl    String?                         @map("preview_audio_url")
  sourceMetadata     Json                            @default("{}") @map("source_metadata") @db.JsonB
  archived           Boolean                         @default(false)
  archivedAt         DateTime?                       @map("archived_at") @db.Timestamptz(6)
  createdAt          DateTime                        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime                        @updatedAt @map("updated_at") @db.Timestamptz(6)

  workspace Workspace               @relation(fields: [workspaceId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  personas  WorkspaceVideoPersona[] @relation("WorkspaceVideoPersonaClonedVoice")

  @@unique([workspaceId, displayNameLower], name: "uniq_workspace_video_cloned_voice_name")
  @@unique([workspaceId, id], name: "uniq_workspace_video_cloned_voice_workspace_id_id")
  @@index([workspaceId, archived])
  @@index([workspaceId, status])
  @@map("workspace_video_cloned_voices")
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum WorkspaceStatus {
  active
  inactive
}

enum WorkspaceRole {
  owner
  member
}

enum AppUserAdminRoleCode {
  ops_admin
  business_admin
  security_admin
  super_admin
}

enum AssistantApplyStatus {
  not_requested
  pending
  in_progress
  succeeded
  failed
  degraded
}

enum AssistantMaterializationSourceAction {
  publish
  rollback
  reset
}

enum AssistantChatSurface {
  web
  telegram
}

enum AssistantChatMessageAuthor {
  user
  assistant
  system
}

enum AssistantMemoryRegistrySourceType {
  web_chat
  memory_write
}

enum AssistantMemoryRegistryClass {
  core
  contextual
}

enum AssistantMemoryRegistryKind {
  fact
  preference
  open_loop
}

enum AssistantTaskRegistrySourceSurface {
  web
}

enum AssistantTaskRegistryControlStatus {
  active
  disabled
  cancelled
}

enum AssistantTaskRegistryAudience {
  user
  assistant
}

enum AssistantPreferredNotificationChannel {
  web
  telegram
  whatsapp
}

enum PlanCatalogStatus {
  active
  inactive
}

enum ToolCatalogToolClass {
  cost_driving
  utility
}

enum ToolCatalogCapabilityGroup {
  knowledge
  automation
  communication
  workspace_ops
}

enum ToolCatalogStatus {
  active
  inactive
}

enum PlanToolActivationStatus {
  active
  inactive
}

enum WorkspaceSubscriptionStatus {
  trialing
  active
  grace_period
  past_due
  paused
  canceled
  expired
}

enum WorkspaceQuotaDimension {
  token_budget
  cost_or_token_driving_tool_class
  active_web_chats_cap
  media_storage_bytes
  knowledge_storage_bytes
}

enum AssistantKnowledgeSourceNamespace {
  assistant_user_workspace
}

enum AssistantKnowledgeSourceKind {
  uploaded_file
}

enum AssistantKnowledgeSourceStatus {
  processing
  ready
  failed
}

enum GlobalKnowledgeSourceScope {
  product
  skill
}

enum KnowledgeRetrievalEventKind {
  search
  fetch
}

enum KnowledgeRetrievalEventSource {
  document
  global
  memory
  chat
  preset
  subscription
}

enum KnowledgeRetrievalMode {
  lexical
  hybrid
}

enum KnowledgeRetrievalOutcome {
  success
  empty
  error
}

enum AttachmentType {
  image
  audio
  voice
  video
  document
  tool_output

  @@map("attachment_type")
}

enum AttachmentProcessingStatus {
  pending
  ready
  failed

  @@map("attachment_processing_status")
}

enum SandboxJobStatus {
  queued
  running
  completed
  failed
  blocked
  cancelled

  @@map("sandbox_job_status")
}

enum SandboxFileOrigin {
  sandbox_output
  runtime_output
  uploaded_attachment

  @@map("sandbox_file_origin")
}

enum AssistantIntegrationProviderKey {
  web_internal
  telegram
  whatsapp
  max
  system_notifications
}

enum AssistantIntegrationSurfaceType {
  web_chat
  telegram_bot
  whatsapp_business
  max_bot
  max_mini_app
  system_notification
}

enum AssistantChannelBindingState {
  active
  inactive
  unconfigured
}

enum AdminNotificationChannelType {
  webhook
}

enum AdminNotificationChannelStatus {
  active
  inactive
}

enum AdminNotificationDeliveryStatus {
  succeeded
  failed
  skipped
}

enum PlatformRolloutStatus {
  in_progress
  applied
  rolled_back
  failed
}

enum PlatformRolloutItemOutcome {
  pending
  succeeded
  degraded
  failed
  skipped
}

enum AbuseSurface {
  web_chat
  telegram
  whatsapp
  max

  @@map("abuse_surface")
}

enum RuntimeTier {
  free_shared_restricted
  paid_shared_restricted
  paid_isolated
}

enum RuntimeConversationChannel {
  web
  telegram
  max_ru
}

enum RuntimeConversationMode {
  direct
  group
}

enum RuntimeTurnReceiptStatus {
  accepted
  completed
  interrupted
  failed
}

model AppUser {
  id                                     String                              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clerkUserId                            String?                             @unique @map("clerk_user_id")
  email                                  String                              @unique
  displayName                            String?                             @map("display_name")
  birthday                               DateTime?                           @map("birthday") @db.Date
  gender                                 String?                             @map("gender") @db.VarChar(32)
  termsOfServiceAcceptedAt               DateTime?                           @map("terms_of_service_accepted_at") @db.Timestamptz(6)
  termsOfServiceVersion                  String?                             @map("terms_of_service_version") @db.VarChar(64)
  privacyPolicyAcceptedAt                DateTime?                           @map("privacy_policy_accepted_at") @db.Timestamptz(6)
  privacyPolicyVersion                   String?                             @map("privacy_policy_version") @db.VarChar(64)
  createdAt                              DateTime                            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                              DateTime                            @updatedAt @map("updated_at") @db.Timestamptz(6)
  assistant                              Assistant?
  workspaceLinks                         WorkspaceMember[]
  publishedAssistantVersion              AssistantPublishedVersion[]         @relation("AssistantVersionPublisher")
  assistantAuditEvents                   AssistantAuditEvent[]               @relation("AssistantAuditActor")
  adminRoles                             AppUserAdminRole[]
  createdAdminNotificationChannels       WorkspaceAdminNotificationChannel[]
  createdPlatformRollouts                AssistantPlatformRollout[]
  platformRolloutItems                   AssistantPlatformRolloutItem[]
  abuseGuardStates                       AssistantAbuseGuardState[]
  createdGlobalKnowledgeSources          GlobalKnowledgeSource[]
  updatedPlatformRuntimeProviderSettings PlatformRuntimeProviderSettings[]   @relation("PlatformRuntimeProviderSettingsUpdatedByUser")
  updatedPlatformRuntimeProviderSecrets  PlatformRuntimeProviderSecret[]     @relation("PlatformRuntimeProviderSecretsUpdatedByUser")

  @@map("app_users")
}

model Workspace {
  id                          String                              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                        String
  locale                      String
  timezone                    String
  status                      WorkspaceStatus
  createdAt                   DateTime                            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                   DateTime                            @updatedAt @map("updated_at") @db.Timestamptz(6)
  assistants                  Assistant[]
  members                     WorkspaceMember[]
  subscription                WorkspaceSubscription?
  quotaAccountingState        WorkspaceQuotaAccountingState?
  quotaUsageEvents            WorkspaceQuotaUsageEvent[]
  assistantAuditEvents        AssistantAuditEvent[]
  adminRoles                  AppUserAdminRole[]
  adminNotificationChannels   WorkspaceAdminNotificationChannel[]
  adminNotificationDeliveries AdminNotificationDelivery[]
  platformRollouts            AssistantPlatformRollout[]
  abuseGuardStates            AssistantAbuseGuardState[]
  toolUsageDailyCounters      WorkspaceToolUsageDailyCounter[]
  chatMessageAttachments      AssistantChatMessageAttachment[]
  knowledgeSources            AssistantKnowledgeSource[]
  knowledgeSourceChunks       AssistantKnowledgeSourceChunk[]
  globalKnowledgeSources      GlobalKnowledgeSource[]
  globalKnowledgeSourceChunks GlobalKnowledgeSourceChunk[]
  knowledgeRetrievalEvents    KnowledgeRetrievalEvent[]
  knowledgeRetrievalRollups   KnowledgeRetrievalRollup[]
  runtimeBundleStates         RuntimeBundleState[]
  runtimeSessions             RuntimeSession[]
  runtimeSessionCompactions   RuntimeSessionCompaction[]
  runtimeTurnReceipts         RuntimeTurnReceipt[]
  sandboxJobs                 SandboxJob[]
  assistantWorkspaceLeases    AssistantWorkspaceLease[]
  assistantFiles              AssistantFile[]
  assistantBackgroundCompactionJobs AssistantBackgroundCompactionJob[]

  @@map("workspaces")
}

model WorkspaceMember {
  id                           String                        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId                  String                        @map("workspace_id") @db.Uuid
  userId                       String                        @map("user_id") @db.Uuid
  role                         WorkspaceRole
  createdAt                    DateTime                      @default(now()) @map("created_at") @db.Timestamptz(6)
  assistant                    Assistant?                    @relation("AssistantWorkspaceScope")
  assistantChats               AssistantChat[]
  assistantMemoryRegistryItems AssistantMemoryRegistryItem[]
  assistantTaskRegistryItems   AssistantTaskRegistryItem[]
  assistantKnowledgeSources    AssistantKnowledgeSource[]
  abuseGuardStates             AssistantAbuseGuardState[]
  workspace                    Workspace                     @relation(fields: [workspaceId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  user                         AppUser                       @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([workspaceId, userId])
  @@map("workspace_members")
}

model Assistant {
  id                           String                                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId                       String                                @unique @map("user_id") @db.Uuid
  workspaceId                  String                                @map("workspace_id") @db.Uuid
  preferredNotificationChannel AssistantPreferredNotificationChannel @default(web) @map("preferred_notification_channel")
  draftDisplayName             String?                               @map("draft_display_name")
  draftInstructions            String?                               @map("draft_instructions")
  draftTraits                  Json?                                 @map("draft_traits") @db.JsonB
  draftAvatarEmoji             String?                               @map("draft_avatar_emoji") @db.VarChar(8)
  draftAvatarUrl               String?                               @map("draft_avatar_url")
  draftAssistantGender         String?                               @map("draft_assistant_gender") @db.VarChar(32)
  draftVoiceProfile            Json?                                 @map("draft_voice_profile") @db.JsonB
  draftArchetypeKey            String?                               @map("draft_archetype_key") @db.VarChar(64)
  draftUpdatedAt               DateTime?                             @map("draft_updated_at") @db.Timestamptz(6)
  applyStatus                  AssistantApplyStatus                  @default(not_requested) @map("apply_status")
  applyTargetVersionId         String?                               @map("apply_target_version_id") @db.Uuid
  applyAppliedVersionId        String?                               @map("apply_applied_version_id") @db.Uuid
  applyRequestedAt             DateTime?                             @map("apply_requested_at") @db.Timestamptz(6)
  applyStartedAt               DateTime?                             @map("apply_started_at") @db.Timestamptz(6)
  applyFinishedAt              DateTime?                             @map("apply_finished_at") @db.Timestamptz(6)
  applyErrorCode               String?                               @map("apply_error_code")
  applyErrorMessage            String?                               @map("apply_error_message")
  configDirtyAt                DateTime?                             @map("config_dirty_at") @db.Timestamptz(6)
  createdAt                    DateTime                              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                    DateTime                              @updatedAt @map("updated_at") @db.Timestamptz(6)
  user                         AppUser                               @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  workspace                    Workspace                             @relation(fields: [workspaceId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  workspaceMember              WorkspaceMember                       @relation("AssistantWorkspaceScope", fields: [workspaceId, userId], references: [workspaceId, userId], onDelete: Restrict, onUpdate: Cascade)
  applyTargetVersion           AssistantPublishedVersion?            @relation("AssistantApplyTargetVersion", fields: [applyTargetVersionId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  applyAppliedVersion          AssistantPublishedVersion?            @relation("AssistantApplyAppliedVersion", fields: [applyAppliedVersionId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  governance                   AssistantGovernance?
  materializedSpecs            AssistantMaterializedSpec[]
  publishedVersions            AssistantPublishedVersion[]
  chats                        AssistantChat[]
  chatMessages                 AssistantChatMessage[]
  memoryRegistryItems          AssistantMemoryRegistryItem[]
  taskRegistryItems            AssistantTaskRegistryItem[]
  knowledgeSources             AssistantKnowledgeSource[]
  knowledgeSourceChunks        AssistantKnowledgeSourceChunk[]
  channelSurfaceBindings       AssistantChannelSurfaceBinding[]
  auditEvents                  AssistantAuditEvent[]
  platformRolloutItems         AssistantPlatformRolloutItem[]
  abuseGuardStates             AssistantAbuseGuardState[]
  abuseAssistantStates         AssistantAbuseAssistantState[]
  abusePeerStates              AssistantAbusePeerState[]
  telegramGroups               AssistantTelegramGroup[]
  chatMessageAttachments       AssistantChatMessageAttachment[]
  knowledgeRetrievalEvents     KnowledgeRetrievalEvent[]
  runtimeBundleStates          RuntimeBundleState[]
  runtimeSessions              RuntimeSession[]
  runtimeSessionCompactions    RuntimeSessionCompaction[]
  runtimeTurnReceipts          RuntimeTurnReceipt[]
  sandboxJobs                  SandboxJob[]
  assistantWorkspaceLeases     AssistantWorkspaceLease[]
  assistantFiles               AssistantFile[]
  backgroundCompactionJobs     AssistantBackgroundCompactionJob[]

  @@unique([workspaceId, userId])
  @@unique([id, userId])
  @@map("assistants")
}

model AssistantChannelSurfaceBinding {
  id               String                          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  assistantId      String                          @map("assistant_id") @db.Uuid
  providerKey      AssistantIntegrationProviderKey @map("provider_key")
  surfaceType      AssistantIntegrationSurfaceType @map("surface_type")
  bindingState     AssistantChannelBindingState    @default(unconfigured) @map("binding_state")
  tokenFingerprint String?                         @map("token_fingerprint") @db.VarChar(128)
  tokenLastFour    String?                         @map("token_last_four") @db.VarChar(4)
  policy           Json?                           @db.JsonB
  config           Json?                           @db.JsonB
  metadata         Json?                           @db.JsonB
  connectedAt      DateTime?                       @map("connected_at") @db.Timestamptz(6)
  disconnectedAt   DateTime?                       @map("disconnected_at") @db.Timestamptz(6)
  createdAt        DateTime                        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime                        @updatedAt @map("updated_at") @db.Timestamptz(6)
  assistant        Assistant                       @relation(fields: [assistantId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([assistantId, providerKey, surfaceType])
  @@index([assistantId, providerKey, bindingState])
  @@map("assistant_channel_surface_bindings")
}

model AssistantPublishedVersion {
  id                     String                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  assistantId            String                     @map("assistant_id") @db.Uuid
  version                Int
  snapshotDisplayName    String?                    @map("snapshot_display_name")
  snapshotInstructions   String?                    @map("snapshot_instructions")
  snapshotTraits         Json?                      @map("snapshot_traits") @db.JsonB
  snapshotAvatarEmoji    String?                    @map("snapshot_avatar_emoji") @db.VarChar(8)
  snapshotAvatarUrl      String?                    @map("snapshot_avatar_url")
  snapshotAssistantGender String?                   @map("snapshot_assistant_gender") @db.VarChar(32)
  snapshotVoiceProfile   Json?                      @map("snapshot_voice_profile") @db.JsonB
  snapshotArchetypeKey   String?                    @map("snapshot_archetype_key") @db.VarChar(64)
  snapshotVoiceDna       Json?                      @map("snapshot_voice_dna") @db.JsonB
  publishedByUserId      String                     @map("published_by_user_id") @db.Uuid
  createdAt              DateTime                   @default(now()) @map("created_at") @db.Timestamptz(6)
  assistant              Assistant                  @relation(fields: [assistantId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  publishedByUser        AppUser                    @relation("AssistantVersionPublisher", fields: [publishedByUserId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  applyTargetAssistants  Assistant[]                @relation("AssistantApplyTargetVersion")
  applyAppliedAssistants Assistant[]                @relation("AssistantApplyAppliedVersion")
  materializedSpec       AssistantMaterializedSpec?
  runtimeBundleState     RuntimeBundleState?
  runtimeSessions        RuntimeSession[]
  runtimeTurnReceipts    RuntimeTurnReceipt[]

  @@unique([assistantId, version])
  @@map("assistant_published_versions")
}

model AssistantGovernance {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  assistantId        String    @unique @map("assistant_id") @db.Uuid
  capabilityEnvelope Json?     @map("capability_envelope")
  secretRefs         Json?     @map("secret_refs")
  policyEnvelope     Json?     @map("policy_envelope")
  memoryControl      Json?     @map("memory_control")
  tasksControl       Json?     @map("tasks_control")
  assistantPlanOverrideCode String? @map("assistant_plan_override_code")
  quotaPlanCode      String?   @map("quota_plan_code")
  quotaHook          Json?     @map("quota_hook")
  auditHook          Json?     @map("audit_hook")
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  assistant          Assistant @relation(fields: [assistantId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@map("assistant_governance")
}

model AppUserAdminRole {
  id          String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String               @map("user_id") @db.Uuid
  workspaceId String?              @map("workspace_id") @db.Uuid
  roleCode    AppUserAdminRoleCode @map("role_code")
  createdAt   DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)
  user        AppUser              @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  workspace   Workspace?           @relation(fields: [workspaceId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@unique([userId, workspaceId, roleCode])
  @@index([workspaceId, roleCode])
  @@map("app_user_admin_roles")
}

model AssistantAuditEvent {
  id            String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId   String?    @map("workspace_id") @db.Uuid
  assistantId   String?    @map("assistant_id") @db.Uuid
  actorUserId   String?    @map("actor_user_id") @db.Uuid
  eventCategory String     @map("event_category") @db.VarChar(64)
  eventCode     String     @map("event_code") @db.VarChar(128)
  outcome       String     @default("succeeded") @db.VarChar(24)
  summary       String     @db.VarChar(255)
  details       Json       @default("{}") @db.JsonB
  createdAt     DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  workspace     Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  assistant     Assistant? @relation(fields: [assistantId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  actorUser     AppUser?   @relation("AssistantAuditActor", fields: [actorUserId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([assistantId, createdAt(sort: Desc)])
  @@index([workspaceId, createdAt(sort: Desc)])
  @@index([eventCategory, createdAt(sort: Desc)])
  @@map("assistant_audit_events")
}

model WorkspaceAdminNotificationChannel {
  id              String                         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId     String                         @map("workspace_id") @db.Uuid
  channelType     AdminNotificationChannelType   @map("channel_type")
  status          AdminNotificationChannelStatus @default(inactive) @map("status")
  endpointUrl     String?                        @map("endpoint_url") @db.VarChar(512)
  signingSecret   String?                        @map("signing_secret") @db.VarChar(256)
  createdByUserId String?                        @map("created_by_user_id") @db.Uuid
  createdAt       DateTime                       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime                       @updatedAt @map("updated_at") @db.Timestamptz(6)
  workspace       Workspace                      @relation(fields: [workspaceId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  createdByUser   AppUser?                       @relation(fields: [createdByUserId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  deliveries      AdminNotificationDelivery[]

  @@unique([workspaceId, channelType])
  @@index([workspaceId, status])
  @@map("workspace_admin_notification_channels")
}

model AdminNotificationDelivery {
  id             String                            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId    String                            @map("workspace_id") @db.Uuid
  channelId      String                            @map("channel_id") @db.Uuid
  signalCode     String                            @map("signal_code") @db.VarChar(128)
  deliveryStatus AdminNotificationDeliveryStatus   @map("delivery_status")
  payload        Json                              @default("{}") @db.JsonB
  errorMessage   String?                           @map("error_message") @db.VarChar(512)
  attemptedAt    DateTime                          @default(now()) @map("attempted_at") @db.Timestamptz(6)
  workspace      Workspace                         @relation(fields: [workspaceId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  channel        WorkspaceAdminNotificationChannel @relation(fields: [channelId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([workspaceId, attemptedAt(sort: Desc)])
  @@index([channelId, attemptedAt(sort: Desc)])
  @@map("admin_notification_deliveries")
}

model PlatformConfigGeneration {
  id                                  String   @id @default("global") @db.VarChar(32)
  generation                          Int      @default(1)
  reminderSchedulerEpoch              Int      @default(1) @map("reminder_scheduler_epoch")
  backgroundCompactionSchedulerEpoch  Int      @default(1) @map("background_compaction_scheduler_epoch")
  updatedAt                           DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("platform_config_generations")
}

model PlatformRuntimeProviderSettings {
  id                        String                          @id @default("global") @db.VarChar(32)
  primaryProvider           String                          @map("primary_provider") @db.VarChar(32)
  primaryModel              String                          @map("primary_model") @db.VarChar(256)
  fallbackProvider          String?                         @map("fallback_provider") @db.VarChar(32)
  fallbackModel             String?                         @map("fallback_model") @db.VarChar(256)
  routingFastModelKey       String?                         @map("routing_fast_model_key") @db.VarChar(256)
  routerPolicy              Json                            @default("{}") @map("router_policy") @db.JsonB
  availableModelsByProvider Json                            @map("available_models_by_provider") @db.JsonB
  updatedByUserId           String?                         @map("updated_by_user_id") @db.Uuid
  createdAt                 DateTime                        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                 DateTime                        @updatedAt @map("updated_at") @db.Timestamptz(6)
  updatedByUser             AppUser?                        @relation("PlatformRuntimeProviderSettingsUpdatedByUser", fields: [updatedByUserId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  secrets                   PlatformRuntimeProviderSecret[]

  @@map("platform_runtime_provider_settings")
}

model PlatformRuntimeProviderSecret {
  id                      String                          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  settingsId              String                          @default("global") @map("settings_id") @db.VarChar(32)
  providerKey             String                          @unique @map("provider_key") @db.VarChar(64)
  encryptionSchemaVersion Int                             @default(1) @map("encryption_schema_version")
  ciphertext              String                          @db.Text
  iv                      String                          @db.VarChar(128)
  authTag                 String                          @map("auth_tag") @db.VarChar(128)
  lastFour                String?                         @map("last_four") @db.VarChar(8)
  updatedByUserId         String?                         @map("updated_by_user_id") @db.Uuid
  createdAt               DateTime                        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime                        @updatedAt @map("updated_at") @db.Timestamptz(6)
  settings                PlatformRuntimeProviderSettings @relation(fields: [settingsId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  updatedByUser           AppUser?                        @relation("PlatformRuntimeProviderSecretsUpdatedByUser", fields: [updatedByUserId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([settingsId])
  @@map("platform_runtime_provider_secrets")
}

model AssistantPlatformRollout {
  id                  String                         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId         String                         @map("workspace_id") @db.Uuid
  createdByUserId     String?                        @map("created_by_user_id") @db.Uuid
  status              PlatformRolloutStatus          @default(in_progress)
  rolloutPercent      Int                            @map("rollout_percent")
  targetPatch         Json                           @map("target_patch") @db.JsonB
  totalAssistants     Int                            @default(0) @map("total_assistants")
  targetedAssistants  Int                            @default(0) @map("targeted_assistants")
  applySucceededCount Int                            @default(0) @map("apply_succeeded_count")
  applyDegradedCount  Int                            @default(0) @map("apply_degraded_count")
  applyFailedCount    Int                            @default(0) @map("apply_failed_count")
  rolledBackAt        DateTime?                      @map("rolled_back_at") @db.Timestamptz(6)
  createdAt           DateTime                       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime                       @updatedAt @map("updated_at") @db.Timestamptz(6)
  workspace           Workspace                      @relation(fields: [workspaceId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  createdByUser       AppUser?                       @relation(fields: [createdByUserId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  items               AssistantPlatformRolloutItem[]

  @@index([workspaceId, createdAt(sort: Desc)])
  @@map("assistant_platform_rollouts")
}

model AssistantPlatformRolloutItem {
  id                   String                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  rolloutId            String                     @map("rollout_id") @db.Uuid
  assistantId          String                     @map("assistant_id") @db.Uuid

{
  "name": "persai-v2-foundation",
  "private": true,
  "packageManager": "pnpm@10.17.1",
  "scripts": {
    "prisma:generate": "corepack pnpm --filter @persai/api run prisma:generate",
    "prisma:migrate:check": "corepack pnpm --filter @persai/api run prisma:migrate:check",
    "lint": "corepack pnpm -r --if-present run lint",
    "typecheck": "corepack pnpm -r --if-present run typecheck",
    "test": "corepack pnpm -r --if-present run test",
    "build": "corepack pnpm -r --if-present run build"
  }
}

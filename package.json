{
  "name": "persai-v2-foundation",
  "private": true,
  "packageManager": "pnpm@10.17.1",
  "scripts": {
    "contracts:generate": "corepack pnpm --filter @persai/contracts run generate",
    "prisma:generate": "corepack pnpm --filter @persai/api run prisma:generate",
    "prisma:migrate:check": "corepack pnpm --filter @persai/api run prisma:migrate:check",
    "openclaw:fork:audit": "node scripts/openclaw-fork-audit.cjs",
    "openclaw:fork:audit:strict": "node scripts/openclaw-fork-audit.cjs --strict",
    "openclaw:fork:update-gate": "node scripts/openclaw-fork-update-gate.cjs",
    "shared-runtime:readiness": "node scripts/shared-runtime-hardening-readiness.cjs",
    "shared-runtime:readiness:strict": "node scripts/shared-runtime-hardening-readiness.cjs --strict",
    "runtime-pools:readiness": "node scripts/runtime-pools-readiness.cjs",
    "runtime-pools:readiness:strict": "node scripts/runtime-pools-readiness.cjs --strict",
    "networkpolicy:readiness": "node scripts/networkpolicy-readiness.cjs",
    "networkpolicy:readiness:strict": "node scripts/networkpolicy-readiness.cjs --strict",
    "format:check": "corepack pnpm exec prettier --check \"apps/**/*.{ts,tsx,js,cjs,json,css}\" \"packages/**/*.{ts,js,cjs,json}\" \".github/**/*.{yml,yaml}\" \"infra/dev/**/*.{yml,yaml,md}\" \"infra/local/**/*.{yml,yaml}\" \"*.{json,md,yml,yaml}\"",
    "lint": "corepack pnpm -r --if-present run lint && corepack pnpm run format:check",
    "typecheck": "corepack pnpm -r --if-present run typecheck",
    "test": "corepack pnpm -r --if-present run test",
    "test:step2": "corepack pnpm --filter @persai/api run test:step2 && corepack pnpm --filter @persai/web run test",
    "build": "corepack pnpm -r --if-present run build"
  },
  "devDependencies": {
    "prettier": "^3.8.1"
  }
}

{
  "name": "persai-v2-foundation",
  "private": true,
  "packageManager": "pnpm@10.17.1",
  "scripts": {
    "contracts:generate": "corepack pnpm --filter @persai/contracts run generate",
    "prisma:generate": "corepack pnpm --filter @persai/api run prisma:generate",
    "prisma:migrate:check": "corepack pnpm --filter @persai/api run prisma:migrate:check",
    "sr10:load": "node scripts/loadtest/run-sr10.cjs",
    "smoke:run": "corepack pnpm --filter @persai/smoke exec tsx run-scenario.ts",
    "smoke:run-all": "corepack pnpm --filter @persai/smoke exec tsx run-scenario.ts --all",
    "format:check": "corepack pnpm exec prettier --check \"apps/**/*.{ts,tsx,js,cjs,json,css}\" \"packages/**/*.{ts,js,cjs,json}\" \"scripts/smoke/**/*.{ts,js,cjs,json}\" \".github/**/*.{yml,yaml}\" \"infra/dev/**/*.{yml,yaml,md}\" \"infra/local/**/*.{yml,yaml}\" \"*.{json,md,yml,yaml}\"",
    "lint": "corepack pnpm -r --if-present run lint && corepack pnpm run format:check",
    "typecheck": "corepack pnpm run prisma:generate && corepack pnpm -r --if-present run typecheck",
    "test": "corepack pnpm -r --if-present run test",
    "test:step2": "corepack pnpm --filter @persai/api run test:step2 && corepack pnpm --filter @persai/web run test",
    "build": "corepack pnpm run prisma:generate && corepack pnpm -r --if-present run build",
    "test:ci-detect-affected": "node --test scripts/ci/detect-affected.test.mjs",
    "test:adr146-foundation": "node --test infra/bootstrap/adr146-sandbox-egress-foundation.test.mjs",
    "test:adr146-release-gate": "node --test scripts/ci/adr146-foundation-release-gate.test.mjs"
  },
  "devDependencies": {
    "prettier": "^3.8.1"
  }
}
